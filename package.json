{
  "name": "ui-etl-tool",
  "version": "1.0.0",
  "description": "Visual ETL pipeline builder with UI",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "tsx watch src/backend/index.ts",
    "dev:frontend": "vite",
    "build": "vite build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@xyflow/react": "^12.10.2",
    "autoprefixer": "^10.4.27",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.0",
    "express": "^4.21.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.20.0",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "tailwindcss": "^3.4.0",
    "vite": "^8.0.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "prisma": "5.22.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
